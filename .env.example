# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Real secrets belong in Supabase Vault / Vercel env, not in source.

# ── Send safety (see CLAUDE.md rule 1) ──────────────────────────────
# sandbox = only TEST_ALLOWLIST numbers can receive anything (default).
# live    = real sends; also requires LIVE_CONFIRM below AND Chris's sign-off.
SEND_MODE=sandbox
# Comma-separated E.164 numbers allowed to receive in sandbox mode.
TEST_ALLOWLIST=+31600000000
# Hard cap on sends per dispatch run (belt-and-braces).
MAX_SENDS_PER_RUN=50
# Must equal exactly I-UNDERSTAND-THIS-SENDS-REAL-WHATSAPP for live mode to send.
LIVE_CONFIRM=

# ── Supabase ────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=              # browser-safe (RLS-gated); the only key in the client
SUPABASE_SERVICE_ROLE_KEY=      # SERVER / EDGE ONLY — never in the browser bundle
SUPABASE_DB_URL=                # for migrations / local tooling

# ── Next.js <-> Edge Function auth ──────────────────────────────────
EDGE_SHARED_SECRET=             # 32-byte high-entropy; sent as x-krofs-edge-secret

# ── Scheduler (external cron -> sweep endpoints; NO pg_cron) ─────────
# A free external cron (e.g. Cloudflare Workers, */15) calls /tick with this
# secret. Ticks also keep the Free Supabase project awake (no 7-day pause).
CRON_SWEEP_SECRET=              # external scheduler must present this to hit /tick
HEALTHCHECK_URL=                # Healthchecks.io ping (dead-man's-switch on the scheduler)

# ── Google Maps Platform (one server key, restricted to these 2 APIs) ─
GOOGLE_MAPS_API_KEY=
GEOCODE_REGION=nl

# ── WhatsApp: Twilio sandbox (dev/testing) ──────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── WhatsApp: Meta Cloud API (production; fill after verification) ───
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=                # HMAC verify of X-Hub-Signature-256 webhooks
META_WEBHOOK_VERIFY_TOKEN=
META_TEMPLATE_INVITE=krofs_uitnodiging
META_TEMPLATE_REMINDER=krofs_herinnering

# ── Rate-limit store (per-token / per-IP on /r/{token}) ─────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Domain / routing ────────────────────────────────────────────────
PUBLIC_BASE_URL=https://bezoek.krofs.nl

# ── Org defaults (mirror the organizations row; see db/001) ─────────
ORG_TIMEZONE=Europe/Amsterdam
START_LAT=52.2478
START_LNG=5.4147
VISIT_MINUTES=30
DAY_START_LOCAL=08:00
DAGDEEL_SPLIT_LOCAL=12:00
MAX_WORKING_MINUTES=480
GEOCODE_REVIEW_KM=75
